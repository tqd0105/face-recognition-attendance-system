# Cổng chạy server Backend
PORT=5000

# Thông tin kết nối Database 
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db

# Chuỗi bí mật mã hóa Token (Thay thế bằng một chuỗi ngẫu nhiên khi chạy thực tế)
JWT_SECRET=your_super_secret_jwt_key_here

# Comma-separated emails allowed to request admin role at login
# Example: admin1@school.edu,admin2@school.edu
ADMIN_EMAILS=
# Optional seed password for the first admin email in ADMIN_EMAILS
ADMIN_SEED_PASSWORD=123456
# Optional seed password for the sample teacher account
TEACHER_SEED_PASSWORD=123456

# Địa chỉ của AI Service (Python FastAPI).
# Nếu chạy ngoài máy thật thì là localhost:8000, chạy trong Docker sau này sẽ là tên service (vd: http://ai_service:8000)
AI_SERVICE_URL=http://localhost:8000

# Face enrollment guardrails
# Minimum quality score accepted during enrollment (0..1)
BIOMETRIC_MIN_QUALITY=0.75
# Re-enrollment must match this student's existing face profile at least this much (0..1)
BIOMETRIC_REENROLL_MIN_SIMILARITY=0.60
# Block enrollment if face is too similar to another student's profile (0..1)
BIOMETRIC_DUPLICATE_SIMILARITY_THRESHOLD=0.20
# If true, always reject when face is similar to any other student above threshold.
BIOMETRIC_STRICT_UNIQUENESS=true

# Attendance liveness guardrails
# If true, realtime recognition and one-face check-in require multiple camera frames.
ATTENDANCE_REQUIRE_LIVENESS=true
# Minimum number of frames the client must send in liveness_frames.
ATTENDANCE_LIVENESS_MIN_FRAMES=4
# Minimum adjacent frame pairs that must show motion.
ATTENDANCE_LIVENESS_REQUIRED_MOVING_PAIRS=2
# Lower this if real users are rejected too often; raise it if photos pass too easily.
ATTENDANCE_LIVENESS_MIN_MOTION_SCORE=5.5
# Students are marked late after this many minutes from session start time.
ATTENDANCE_LATE_AFTER_MINUTES=15

# Session lifecycle scheduler
# How often the backend checks whether sessions should auto-start/auto-stop.
SESSION_LIFECYCLE_INTERVAL_MS=15000
# Timezone used when comparing Session start/end times.
SESSION_TIMEZONE=Asia/Ho_Chi_Minh

# Email notifications
# Enable only after SMTP Gmail credentials are configured.
EMAIL_ENABLED=false
EMAIL_FROM_NAME=Face Recognition Attendance System
EMAIL_FROM_ADDRESS=your_gmail_address@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail_address@gmail.com
# Use a Gmail App Password, not the normal Gmail password.
SMTP_PASS=your_gmail_app_password
# How often the backend checks upcoming sessions and completed absences.
NOTIFICATION_JOB_INTERVAL_MS=60000
# Send schedule reminders this many minutes before a session starts.
SCHEDULE_REMINDER_BEFORE_MINUTES=120
