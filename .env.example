# Thông tin kết nối Database dùng chung cho Docker hoặc các tool bên ngoài
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_NAME=attendance_db
DB_PORT=5432

# Attendance liveness guardrails used by backend container
ATTENDANCE_REQUIRE_LIVENESS=true
ATTENDANCE_LIVENESS_MIN_FRAMES=4
ATTENDANCE_LIVENESS_REQUIRED_MOVING_PAIRS=2
ATTENDANCE_LIVENESS_MIN_MOTION_SCORE=5.5
AI_LIVENESS_MIN_FRAMES=6
AI_LIVENESS_MIN_POSE_CHANGE=0.1
AI_LIVENESS_MIN_QUALITY=0.6
AI_LIVENESS_SAME_FACE_SIMILARITY=0.65
